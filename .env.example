# ============================================
# KLYNCoin Server Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3456
JWT_SECRET=klyncoin-secret-2024-seguro

# --- Supabase PostgreSQL ---
# Get your connection string from Supabase Dashboard:
#   Project Settings > Database > Connection string > URI (with password)
# Format: postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.gmhiblcjxwqdurltwzrv.supabase.co:5432/postgres

# --- BSCScan API (for auto-deposit detection) ---
# Get your free API key from: https://bscscan.com/register (then MyApiKey section)
# Leave empty to run in manual-verify mode
BSCSCAN_API_KEY=

# --- Master USDT Wallet (BSC BEP20) ---
# The wallet address where users send USDT deposits.
# Must be a BSC-compatible address (0x...)
MASTER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# --- Check Intervals ---
# How often (in ms) the background checker polls BSCScan for new deposits
CHECK_INTERVAL=60000

# How often (in ms) the frontend polls for deposit status
FRONTEND_POLL=10000